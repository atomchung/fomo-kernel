{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fomo-kernel.local/schemas/question-surface.schema.json",
  "title": "Fomo Kernel Private Question Surfaces",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "session_id", "surfaces"],
  "properties": {
    "schema_version": {"const": 1},
    "session_id": {"type": "string", "minLength": 1},
    "surfaces": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/surface"}
    }
  },
  "$defs": {
    "surface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "question_id",
        "stem",
        "stem_grounding_refs",
        "options",
        "none_of_above"
      ],
      "properties": {
        "question_id": {"type": "string", "minLength": 1},
        "stem": {"type": "string", "minLength": 1, "maxLength": 1000},
        "stem_grounding_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/grounding_ref"}
        },
        "options": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["label", "description", "maps_to", "grounding_refs"],
            "properties": {
              "label": {"type": "string", "minLength": 1, "maxLength": 160},
              "description": {"type": "string", "minLength": 1, "maxLength": 700},
              "maps_to": {"type": "string", "minLength": 1},
              "grounding_refs": {
                "type": "array",
                "uniqueItems": true,
                "items": {"$ref": "#/$defs/grounding_ref"}
              }
            }
          }
        },
        "none_of_above": {
          "type": "object",
          "additionalProperties": false,
          "required": ["label", "description"],
          "properties": {
            "label": {"type": "string", "minLength": 1, "maxLength": 160},
            "description": {"type": "string", "minLength": 1, "maxLength": 500}
          }
        },
        "clarification": {
          "type": "object",
          "additionalProperties": false,
          "required": ["stem", "grounding_refs"],
          "properties": {
            "stem": {"type": "string", "minLength": 1, "maxLength": 1000},
            "grounding_refs": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {"$ref": "#/$defs/grounding_ref"}
            }
          }
        }
      }
    },
    "grounding_ref": {
      "enum": [
        "context.ticker",
        "context.prior_thesis.text",
        "context.asked_because",
        "context.headline_dimension.label"
      ]
    }
  }
}
