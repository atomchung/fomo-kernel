{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fomo-kernel.local/schemas/session-bundle.schema.json",
  "title": "Fomo Kernel Canonical Session Bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "session_id",
    "route",
    "language",
    "review_plan",
    "engine_state",
    "engine_card",
    "answers",
    "narrative",
    "thesis_updates",
    "thesis_decisions",
    "commitment",
    "observations"
  ],
  "properties": {
    "schema_version": {
      "const": 2
    },
    "engine_version": {
      "type": "object",
      "required": [
        "id",
        "source"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "source": {
          "enum": [
            "file",
            "git",
            "unknown"
          ]
        },
        "dirty": {
          "type": "boolean"
        }
      }
    },
    "session_id": {
      "type": "string"
    },
    "route": {
      "enum": [
        "first_review",
        "weekly_review",
        "snapshot_review",
        "test_drive"
      ]
    },
    "language": {
      "enum": [
        "zh-TW",
        "en"
      ]
    },
    "review_plan": {
      "$ref": "review-plan.schema.json"
    },
    "engine_state": {
      "type": "object"
    },
    "engine_card": {
      "type": "object"
    },
    "answers": {
      "$ref": "answers.schema.json"
    },
    "narrative": {
      "$ref": "narrative.schema.json"
    },
    "thesis_updates": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "schema_version": {
            "type": "integer"
          },
          "thesis_id": {
            "type": "string"
          },
          "event_id": {
            "type": "string"
          },
          "revises": {
            "type": [
              "string",
              "null"
            ]
          },
          "cycle_id": {
            "type": "string"
          },
          "status": {
            "enum": [
              "active",
              "open",
              "still",
              "modified",
              "falsified",
              "closed"
            ]
          },
          "position_status": {
            "enum": [
              "open",
              "closed"
            ]
          }
        }
      }
    },
    "thesis_decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "schema_version": {
            "type": "integer"
          },
          "thesis_id": {
            "type": "string"
          },
          "event_id": {
            "type": "string"
          },
          "revises": {
            "type": [
              "string",
              "null"
            ]
          },
          "cycle_id": {
            "type": "string"
          },
          "decision_cursor": {
            "type": [
              "string",
              "null"
            ]
          },
          "evidence_id": {
            "type": "string"
          },
          "provenance": {
            "type": "object",
            "properties": {
              "source": {
                "type": "string"
              },
              "source_state": {
                "enum": [
                  "captured",
                  "confirmed",
                  "evaluated"
                ]
              },
              "captured_at": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "observed_at": {
                "type": [
                  "string",
                  "null"
                ]
              }
            }
          },
          "evaluation": {
            "type": "object",
            "properties": {
              "state": {
                "enum": [
                  "pending",
                  "confirmed",
                  "weakened",
                  "falsified",
                  "insufficient"
                ]
              },
              "evaluated_at": {
                "type": [
                  "string",
                  "null"
                ]
              }
            }
          }
        }
      }
    },
    "headline_motive_events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "event",
          "schema_version",
          "event_id",
          "session_id",
          "question_id",
          "decision",
          "context",
          "review_date"
        ],
        "additionalProperties": false,
        "properties": {
          "event": {"const": "headline_motive_decision"},
          "schema_version": {"const": 1},
          "event_id": {
            "type": "string",
            "pattern": "^headline-motive-[a-f0-9]{16}$"
          },
          "session_id": {"type": "string"},
          "question_id": {"type": "string"},
          "decision": {
            "enum": [
              "deliberate_plan",
              "emotional_reaction",
              "external_constraint"
            ]
          },
          "context": {
            "$ref": "question-opportunity.schema.json#/properties/context"
          },
          "review_date": {"type": ["string", "null"]}
        }
      }
    },
    "exit_narratives": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "schema_version": {
            "type": "integer"
          },
          "thesis_id": {
            "type": "string"
          },
          "event_id": {
            "type": "string"
          },
          "revises": {
            "type": [
              "string",
              "null"
            ]
          },
          "cycle_id": {
            "type": "string"
          },
          "exit_kind": {
            "enum": [
              "full",
              "reduce"
            ]
          }
        }
      }
    },
    "commitment": {
      "type": [
        "object",
        "null"
      ]
    },
    "observations": {
      "type": "array"
    },
    "question_surfaces": {
      "$ref": "question-surface.schema.json"
    },
    "question_presentations": {
      "type": "array",
      "items": {"type": "object"}
    },
    "revisit_resolutions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "type",
          "revisit_id",
          "checkpoint",
          "status",
          "date",
          "session_id"
        ],
        "properties": {
          "type": {
            "const": "resolution"
          },
          "revisit_id": {
            "type": "string"
          },
          "checkpoint": {
            "enum": [
              "30",
              "60",
              "90"
            ]
          },
          "status": {
            "enum": [
              "still_valid",
              "modified",
              "falsified"
            ]
          },
          "date": {
            "type": [
              "string",
              "null"
            ]
          },
          "session_id": {
            "type": "string"
          },
          "note": {
            "type": "string",
            "maxLength": 500
          }
        },
        "additionalProperties": false
      }
    },
    "initial_thesis_events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "event",
          "schema_version",
          "event_id",
          "session_id",
          "cycle_id",
          "choice",
          "review_date"
        ],
        "properties": {
          "event": {"const": "initial_thesis"},
          "schema_version": {"const": 1},
          "event_id": {"type": "string"},
          "session_id": {"type": "string"},
          "cycle_id": {"type": "string"},
          "ticker": {"type": ["string", "null"]},
          "choice": {
            "enum": ["planned_entry", "momentum_follow", "external_call", "no_clear_thesis"]
          },
          "note": {"type": ["string", "null"], "maxLength": 500},
          "cost_basis": {"type": ["number", "null"]},
          "currency": {"type": ["string", "null"]},
          "review_date": {"type": ["string", "null"]}
        },
        "additionalProperties": false
      }
    },
    "rule_breach_decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "event",
          "schema_version",
          "event_id",
          "session_id",
          "rule_id",
          "problem_key",
          "breach_week",
          "decision",
          "review_date"
        ],
        "properties": {
          "event": {"const": "rule_breach_decision"},
          "schema_version": {"const": 1},
          "event_id": {"type": "string"},
          "session_id": {"type": "string"},
          "rule_id": {"type": "string"},
          "rule_text": {"type": ["string", "null"]},
          "problem_key": {"type": ["string", "null"]},
          "breach_week": {"type": "string"},
          "evidence": {"type": "array", "items": {"type": "object"}},
          "decision": {"enum": ["keep_tracking", "revise_rule", "exception"]},
          "note": {"type": ["string", "null"], "maxLength": 500},
          "review_date": {"type": ["string", "null"]},
          "recent_count": {"type": ["integer", "null"], "minimum": 0},
          "recent_amount": {"type": ["number", "null"]},
          "trend": {"enum": ["better", "flat", "worse", null]}
        },
        "additionalProperties": false
      }
    }
  }
}
