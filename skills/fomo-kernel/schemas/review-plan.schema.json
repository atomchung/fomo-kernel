{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fomo-kernel.local/schemas/review-plan.schema.json",
  "title": "Fomo Kernel Review Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "session_id",
    "status",
    "route",
    "flow_path",
    "language",
    "persist",
    "state_root",
    "input",
    "state_snapshot",
    "question_queue",
    "missing_thesis_positions",
    "card_plan",
    "engine_card",
    "engine_state"
  ],
  "properties": {
    "schema_version": {
      "const": 2
    },
    "engine_version": {
      "type": "object",
      "required": [
        "id",
        "source"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "source": {
          "enum": [
            "file",
            "git",
            "unknown"
          ]
        },
        "dirty": {
          "type": "boolean"
        }
      }
    },
    "status": {
      "const": "awaiting_answers"
    },
    "route": {
      "enum": [
        "first_review",
        "weekly_review",
        "snapshot_review",
        "test_drive"
      ]
    },
    "flow_path": {
      "type": "string"
    },
    "language": {
      "enum": [
        "zh-TW",
        "en"
      ]
    },
    "persist": {
      "type": "boolean"
    },
    "state_root": {
      "type": "string"
    },
    "input": {
      "type": "object",
      "required": [
        "paths",
        "kind",
        "fingerprint"
      ],
      "properties": {
        "paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "kind": {
          "enum": [
            "trades_csv",
            "positions_snapshot"
          ]
        },
        "fingerprint": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "engine_meta": {
          "type": "string"
        },
        "ledger_ingest": {
          "type": [
            "object",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "state_snapshot": {
      "type": "object"
    },
    "question_queue": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "kind",
          "required",
          "question",
          "options"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "kind": {
            "enum": [
              "add_thesis",
              "headline_motive",
              "revisit",
              "rule_breach",
              "due_revisit",
              "initial_thesis",
              "exit_consistency"
            ]
          },
          "ticker": {
            "type": [
              "string",
              "null"
            ]
          },
          "cycle_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "required": {
            "type": "boolean"
          },
          "question": {
            "type": "string",
            "minLength": 1
          },
          "options": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "object",
              "required": [
                "value",
                "label",
                "description"
              ],
              "properties": {
                "value": {
                  "type": "string"
                },
                "label": {
                  "type": "string"
                },
                "description": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            }
          },
          "prior_thesis_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "prior_event_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "decision_cursor": {
            "type": [
              "string",
              "null"
            ]
          },
          "asked_because": {
            "type": [
              "string",
              "null"
            ]
          },
          "question_opportunity": {
            "$ref": "question-opportunity.schema.json"
          },
          "revisit_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "exit_kind": {
            "enum": [
              "full",
              "reduce",
              null
            ]
          },
          "exit_date": {
            "type": [
              "string",
              "null"
            ]
          },
          "exit_price": {
            "type": [
              "number",
              "null"
            ]
          },
          "shares_sold": {
            "type": [
              "number",
              "null"
            ]
          },
          "shares_before": {
            "type": [
              "number",
              "null"
            ]
          },
          "currency": {
            "type": [
              "string",
              "null"
            ]
          },
          "exit_notional": {
            "type": [
              "number",
              "null"
            ]
          },
          "cost_basis": {
            "type": [
              "number",
              "null"
            ]
          },
          "checkpoint": {
            "enum": [
              "30",
              "60",
              "90"
            ]
          },
          "due_date": {
            "type": "string"
          },
          "swaps": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "compare": {
            "type": [
              "object",
              "null"
            ]
          },
          "prior_exit_reason": {
            "type": [
              "string",
              "null"
            ]
          },
          "prior_note": {
            "type": [
              "string",
              "null"
            ]
          },
          "horizon_marker": {
            "type": [
              "object",
              "null"
            ]
          },
          "rule_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "rule_text": {
            "type": [
              "string",
              "null"
            ]
          },
          "problem_key": {
            "type": [
              "string",
              "null"
            ]
          },
          "breach_week": {
            "type": "string"
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "recent_count": {
            "type": "integer",
            "minimum": 0
          },
          "recent_amount": {
            "type": "number"
          },
          "trend": {
            "enum": [
              "better",
              "flat",
              "worse",
              null
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "missing_thesis_positions": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "authoring_contract": {
      "type": "object",
      "$comment": "Engine-derived authoring vocabulary (#251). The single source of truth is thesis.MATURITY_VALUES, thesis.INFERENCE_ENUMS, and card_renderer.ALLOWED_NARRATIVE; a contract test pins the equivalence. Optional so plans prepared before #251 stay readable."
    },
    "card_plan": {
      "type": "object",
      "properties": {
        "horizon_ids": {
          "type": "array",
          "items": {
            "enum": ["weeks", "quarters", "years"]
          },
          "minItems": 3,
          "maxItems": 3,
          "uniqueItems": true
        },
        "question_limit": {
          "type": "integer",
          "minimum": 0,
          "$comment": "The active route's maximum question count (#291). Kept for shape compatibility; the full band is in question_policy."
        },
        "question_policy": {
          "type": "object",
          "additionalProperties": false,
          "required": ["route", "min", "max"],
          "properties": {
            "route": {"type": ["string", "null"]},
            "min": {"type": "integer", "minimum": 0},
            "max": {"type": "integer", "minimum": 0}
          }
        },
        "question_selection": {
          "type": "object",
          "$comment": "Plan-internal QA/agent-facing report of how the density band was filled (#291); never rendered on the card.",
          "additionalProperties": false,
          "required": ["route", "min", "max", "eligible", "selected", "shortfall_reason", "rejected"],
          "properties": {
            "route": {"type": ["string", "null"]},
            "min": {"type": "integer", "minimum": 0},
            "max": {"type": "integer", "minimum": 0},
            "eligible": {"type": "integer", "minimum": 0},
            "selected": {"type": "integer", "minimum": 0},
            "shortfall_reason": {
              "enum": [null, "insufficient_eligible_candidates"]
            },
            "rejected": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["id", "kind", "cycle_id", "reason"],
                "properties": {
                  "id": {"type": ["string", "null"]},
                  "kind": {"type": ["string", "null"]},
                  "cycle_id": {
                    "type": ["string", "null"],
                    "$comment": "Stable join key present whenever a cycle is known (initial_thesis, add_thesis, cycle-bearing over_max rows); null for rule_breach or headline_motive."
                  },
                  "reason": {
                    "enum": [
                      "over_max_capacity",
                      "capture_limit",
                      "rule_breach_limit",
                      "initial_thesis_limit",
                      "already_captured",
                      "has_existing_thesis"
                    ]
                  }
                }
              }
            }
          }
        }
      }
    },
    "engine_card": {
      "type": "object"
    },
    "engine_state": {
      "type": "object"
    }
  }
}
