{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fomo-kernel.local/schemas/narrative.schema.json",
  "title": "Fomo Kernel Prose-only Narrative",
  "type": "object",
  "additionalProperties": false,
  "required": ["headline", "mirror"],
  "properties": {
    "headline": {"type": "string", "minLength": 1, "pattern": "^\\D+$"},
    "mirror": {"type": "string", "minLength": 1, "pattern": "^\\D+$"},
    "counterfactual": {"type": "string", "minLength": 1, "pattern": "^\\D+$"},
    "rule_rationale": {"type": "string", "minLength": 1, "pattern": "^\\D+$"},
    "strength": {"type": "string", "minLength": 1, "pattern": "^\\D+$"},
    "honesty": {
      "type": "object",
      "description": "One qualitative sentence per triggered honesty-ledger key; preview fails unless every required_honesty_keys entry is covered (#82: conditions live in the engine, wording stays with the agent).",
      "additionalProperties": {"type": "string", "minLength": 1, "pattern": "^\\D+$"}
    }
  }
}
